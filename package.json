    "@mui/material": "^9.0.0",
    "@mui/x-data-grid": "^9.0.1",
    "@mui/x-tree-view": "^9.0.1",
    "electron-store": "^11.0.2",
    "monaco-editor": "^0.55.1",
    "mssql": "^12.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.10.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
